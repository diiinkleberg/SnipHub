{
  "name": "sniphub",
  "version": "1.0.0",
  "description": "Code snippet sharing platform",
  "main": "index.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"wait-on http://localhost:5000 && npm run client\" \"npm run show-info\"",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "show-info": "wait-on http://localhost:5000 http://localhost:3000 && node server/info.js",
    "seed": "node server/seedDB.js"
  },
  "keywords": [
    "code",
    "snippets",
    "sharing",
    "development"
  ],
  "author": "Anton",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
